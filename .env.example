# ─────────────────────────────────────────────────────────────────────────────
# nexify-ai (Innlegg) — environment variables
# Copy to `.env` and fill in. The server validates required keys at boot
# (server/_core/validateEnv.ts) and refuses to start if any are missing.
# Tags: [REQUIRED] always · [PROD] required in production · [REC] recommended · [OPT] optional
# ─────────────────────────────────────────────────────────────────────────────

# ── Core ─────────────────────────────────────────────────────────────────────
NODE_ENV=production
JWT_SECRET=                      # [REQUIRED] >=32 random chars — signs session cookies. NEVER reuse/rotate-without-care (logs users out)
DATABASE_URL=                    # [REQUIRED] mysql://user:pass@host:3306/db (MySQL/TiDB)
PUBLIC_SITE_URL=https://innlegg.no   # [PROD] canonical site URL (OAuth redirects, payment success/cancel, sitemap)

# ── AI / LLM ─────────────────────────────────────────────────────────────────
OPENAI_API_KEY=                  # [PROD] sk-... — text generation + DALL·E images
# BUILT_IN_FORGE_API_URL=        # [OPT] OpenAI-compatible proxy base (default https://api.openai.com)
# BUILT_IN_FORGE_API_KEY=        # [OPT] falls back to OPENAI_API_KEY
# HUGGINGFACE_API_KEY=           # [OPT] HF inference, if used
# CONTENT_MODEL=gpt-4o-mini      # [OPT] quality tier: post generation + "enhance idea". Set gpt-4o for higher Norwegian quality
# LLM_MODEL=gpt-4o-mini          # [OPT] light tier: hashtags, trend analysis, quick improve, voice summary
# IMAGE_PROVIDER=openai          # [OPT] "openai" (DALL·E) or "fal" (fal.ai FLUX — best quality/cost)
# IMAGE_MODEL=                   # [OPT] per-provider override (openai: dall-e-3 | gpt-image-1; fal: fal-ai/flux/dev)
# FAL_API_KEY=                   # [OPT] required when IMAGE_PROVIDER=fal

# ── Security / crypto ────────────────────────────────────────────────────────
TOKEN_ENCRYPTION_KEY=            # [PROD] random secret — AES-256-GCM encryption of stored OAuth tokens at rest

# ── Rate limiting (distributed) ──────────────────────────────────────────────
REDIS_URL=                       # [REC] redis(s)://... (Upstash) — without it, rate limiting is in-memory & ineffective on serverless

# ── Background scheduler ─────────────────────────────────────────────────────
# RUN_SCHEDULER=true             # [OPT] in-process auto-publish cron. MUST run on exactly ONE instance.
                                 #       single container: leave unset/"true". Scaled/serverless: "false" on web
                                 #       instances, "true" on ONE dedicated worker (or use an external cron).

# ── Payments: Stripe ─────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=               # [PROD] sk_live_...
STRIPE_WEBHOOK_SECRET=           # [PROD] whsec_... — webhook signature verification (fail-closed)

# ── Payments: Vipps (Norway) ─────────────────────────────────────────────────
VIPPS_CLIENT_ID=                 # [REC] if Vipps enabled
VIPPS_CLIENT_SECRET=
VIPPS_SUBSCRIPTION_KEY=
VIPPS_MERCHANT_SERIAL_NUMBER=
VIPPS_SECRET_KEY=                # [REC] webhook HMAC secret — without it Vipps webhooks are rejected (fail-closed)
VIPPS_ENVIRONMENT=production     # production | test
VIPPS_CALLBACK_PREFIX=           # public https base for Vipps callbacks
# Vipps Login (optional, separate from payments)
# VIPPS_LOGIN_CLIENT_ID=
# VIPPS_LOGIN_CLIENT_SECRET=
# VIPPS_LOGIN_REDIRECT_URI=

# ── Auth: Google OAuth ───────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Telegram bot ─────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=              # 123456:ABC... from @BotFather
TELEGRAM_WEBHOOK_SECRET=         # [REC] secret token — without it the Telegram webhook is rejected (fail-closed)

# ── Social publishing (per-platform OAuth; LinkedIn app creds also settable via admin UI) ──
# LINKEDIN_CLIENT_ID=
# LINKEDIN_CLIENT_SECRET=
# LINKEDIN_REDIRECT_URI=
# TWITTER_CLIENT_ID=
# TWITTER_CLIENT_SECRET=
# TWITTER_REDIRECT_URI=
# INSTAGRAM_CLIENT_ID=
# INSTAGRAM_CLIENT_SECRET=
# INSTAGRAM_REDIRECT_URI=
# FACEBOOK_CLIENT_ID=
# FACEBOOK_CLIENT_SECRET=
# FACEBOOK_REDIRECT_URI=

# ── Object storage (S3 — generated images/uploads) ───────────────────────────
# The AWS SDK reads these from the standard env automatically:
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=
# S3_BUCKET=

# ── Email (SendGrid) ─────────────────────────────────────────────────────────
# SENDGRID_API_KEY=
# SENDGRID_FROM_EMAIL=no-reply@innlegg.no

# ── Observability ────────────────────────────────────────────────────────────
# SENTRY_DSN=                    # [REC] error/security event reporting

# ── Misc ─────────────────────────────────────────────────────────────────────
# OWNER_OPEN_ID=                 # openId of the owner account (auto-granted admin)
# ENABLE_DEV_LOGIN=              # [DEV ONLY] set "true" to enable /api/auth/dev-login (never in prod)

# ── Client (Vite, build-time — must be set when building the frontend) ────────
VITE_SITE_URL=https://innlegg.no
# VITE_GA4_ID=                   # Google Analytics 4 measurement id
# VITE_ANALYTICS_ENDPOINT=       # self-hosted analytics (umami) base
# VITE_ANALYTICS_WEBSITE_ID=
